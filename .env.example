# ═══════════════════════════════════════════════════════════════════════════
#  Craftsman APP — vzor prostředí (ZKOPÍRUJ do .env.local a vyplň)
# ═══════════════════════════════════════════════════════════════════════════
#  Tady jsou jen NÁZVY proměnných, žádné hodnoty. Skutečné klíče patří do
#  .env.local, který je v .gitignore a nikdy se nepushuje na GitHub.
#
#  cp .env.example .env.local   → pak doplň hodnoty
# ═══════════════════════════════════════════════════════════════════════════

# --- AI (jádro appky) --------------------------------------
# Vytěžení poptávky z řeči/mailu a diagnóza střechy.
ANTHROPIC_API_KEY=
# Vizualizace střechy (render nové krytiny na fotku zákazníka).
GEMINI_API_KEY=
# Hlas → text (majster diktuje slovensky na střeše).
ELEVENLABS_API_KEY=
# Automatické najití střechy na fotce (fal.ai). Nepovinné pro demo.
FAL_KEY=

# --- Supabase (ostrý provoz: databáze + úložiště médií) -----
# Když jsou tyhle DVA vyplněné, appka běží na databázi. Když ne, jede na
# paměti/localStorage (demo režim). Najdeš je v Supabase: Project Settings →
# API. Service-role klíč je TAJNÝ, patří jen sem (na server), nikdy do klienta.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Pre prihlásenie remeselníkov (klient). URL je rovnaká; ANON kľúč je VEREJNÝ.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Nastavení AI modelů (mají rozumné výchozí hodnoty) -----
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_SIZE=
MAX_PHOTO_PX=
ANTHROPIC_MODEL=

# --- Push notifikácie (Web Push / VAPID) -------------------
# Vygeneruj JEDNORAZOVO: npx web-push generate-vapid-keys --json
# Public kľúč ide do klienta (odber), private zostáva na serveri.
# VAPID_SUBJECT = mailto: alebo URL kontakt na prevádzkovateľa.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- White-label branding instance -------------------------
TENANT_NAME=
TENANT_PRIMARY_COLOR=
TENANT_LOCALE=
TENANT_CURRENCY=
